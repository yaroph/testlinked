# Cloud Run backend environment
PORT=8787
BNI_REALTIME_HTTP_URL=https://bni-linked-backend-xxxxx-ew.a.run.app
BNI_REALTIME_WS_URL=wss://bni-linked-backend-xxxxx-ew.a.run.app
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.europe-west1.firebasedatabase.app
FIREBASE_PROJECT_ID=your-project-id
BNI_FIREBASE_STORE_NAMESPACE=
BNI_BACKUP_BUCKET=your-project-id-rtdb-backups
BNI_BACKUP_PREFIX=rtdb
BNI_SESSION_MAX_IDLE_MS=2592000000
BNI_PRESENCE_TTL_MS=120000
BNI_EXPORT_RETENTION_DAYS=45

# Optional: inline service account JSON for local runs
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk-xxx@your-project-id.iam.gserviceaccount.com"}

# Optional: local-only secrets for direct node runs
# BNI_REALTIME_SECRET=replace-with-a-long-random-secret
# BNI_MAINTENANCE_SECRET=replace-with-another-random-secret

# Optional: legacy Netlify Blobs access, only for one-shot migration
# NETLIFY_SITE_ID=your-netlify-site-id
# NETLIFY_AUTH_TOKEN=your-netlify-personal-access-token

# Optional app auth settings
# BNI_LINKED_KEY=your-admin-api-key
# BNI_LINKED_REQUIRE_AUTH=1
