# Netlify site environment
BNI_REALTIME_SECRET=replace-with-a-long-random-secret
BNI_REALTIME_HTTP_URL=https://realtime.example.com
BNI_REALTIME_WS_URL=wss://realtime.example.com

# External realtime server environment
PORT=8787
NETLIFY_SITE_ID=your-netlify-site-id
NETLIFY_AUTH_TOKEN=your-netlify-personal-access-token

# Optional aliases supported by the external realtime server
# BNI_NETLIFY_SITE_ID=your-netlify-site-id
# BNI_NETLIFY_AUTH_TOKEN=your-netlify-personal-access-token
