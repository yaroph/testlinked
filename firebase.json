{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".firebase/**",
      ".git/**",
      ".github/**",
      ".netlify/**",
      "node_modules/**",
      "**/.*",
      "**/node_modules/**",
      "netlify/**",
      "realtime/**",
      "tests/**",
      "scripts/**",
      "test-results/**",
      "ux-audit-shots/**",
      "Dockerfile",
      "package.json",
      "package-lock.json",
      "playwright.config.cjs",
      "README.md",
      "render.yaml",
      "railway.json",
      "deno.lock"
    ],
    "headers": [
      {
        "source": "/map/carte.jpg",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "run": {
          "serviceId": "bni-linked-backend",
          "region": "europe-west1"
        }
      },
      {
        "source": "/.netlify/functions/**",
        "run": {
          "serviceId": "bni-linked-backend",
          "region": "europe-west1"
        }
      },
      {
        "source": "/health",
        "run": {
          "serviceId": "bni-linked-backend",
          "region": "europe-west1"
        }
      },
      {
        "source": "/api/health",
        "run": {
          "serviceId": "bni-linked-backend",
          "region": "europe-west1"
        }
      }
    ]
  }
}
